# Ejemplo de variables de entorno
# Copia este archivo a .env y configura tus valores reales

# ========== Base de datos MySQL (Railway) ==========
DB_HOST=localhost
DB_PORT=3306
DB_NAME=don_fano_asistencias
DB_USER=root
DB_PASSWORD=tu_password

# ========== Base de datos PostgreSQL (Render - descomentar si usas PostgreSQL) ==========
# DATABASE_URL=postgresql://usuario:contraseña@host:puerto/base_datos
# PGDATABASE=
# PGUSER=
# PGPASSWORD=
# PGHOST=
# PGPORT=5432

# ========== Autenticación ==========
JWT_SECRET=cambia_esto_en_produccion_secreto_muy_seguro_12345

# ========== Configuración del Servidor ==========
NODE_ENV=development
PORT=3000

# ========== Timezone ==========
TZ=America/Asuncion
